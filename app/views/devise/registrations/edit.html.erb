<div class="container-fluid mb-5 pb-5 mt-4">
  <div class="glass-card mb-4 animate-entrance" style="animation-delay: 0.1s;">
    <div class="d-flex align-items-center">
      <div class="profile-avatar me-3">
        <i class="bi bi-person-circle text-primary" style="font-size: 3rem;"></i>
      </div>
      <div>
        <h2 class="h5 mb-1"><%= resource.email %></h2>
        <p class="text-secondary small mb-0">会員ランク: ポイ活ビギナー</p>
      </div>
    </div>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "animate-entrance" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <!-- 一般設定 -->
    <div class="glass-card mb-3" style="animation-delay: 0.2s;">
      <h3 class="h6 font-weight-bold mb-3">⚙️ 一般設定</h3>
      
      <div class="form-group mb-4">
        <%= f.label :email, "メールアドレス", class: "small text-secondary mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control border-0 bg-light rounded-pill px-3" %>
      </div>

      <div class="mt-4 pt-3 border-top border-light">
        <h4 class="h6 mb-2 font-weight-bold">お知らせ通知について</h4>
        <p class="extra-small text-secondary mb-3">
          通知のスケジュールは、設定中の「コース」に基づいて自動制御されます。<br>
          現在のコース：<strong><%= resource.selected_course_name %></strong>
        </p>
        <%= link_to courses_path, class: "btn btn-sm btn-outline-primary rounded-pill px-3 py-1", data: { turbo: false } do %>
          <i class="bi bi-compass me-1"></i>コースを変更する
        <% end %>
      </div>
    </div>

    <!-- セキュリティ設定（パスワード変更） -->
    <div class="glass-card mb-3" style="animation-delay: 0.3s;">
      <div class="d-flex align-items-center justify-content-between mb-3" data-bs-toggle="collapse" href="#passwordSettings" role="button">
        <h3 class="h6 font-weight-bold mb-0">🔒 セキュリティ設定</h3>
        <i class="bi bi-chevron-down text-secondary"></i>
      </div>
      
      <div class="collapse" id="passwordSettings">
        <div class="alert alert-info py-2 extra-small mb-3">
          パスワードを変更する場合のみ入力してください。
        </div>
        <div class="form-group mb-3">
          <%= f.label :password, "新しいパスワード", class: "small text-secondary mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control border-0 bg-light rounded-pill px-3" %>
        </div>
        <div class="form-group mb-4">
          <%= f.label :password_confirmation, "パスワード（確認）", class: "small text-secondary mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control border-0 bg-light rounded-pill px-3" %>
        </div>
      </div>
    </div>

    <!-- 更新確認 -->
    <div class="glass-card mb-4" style="animation-delay: 0.4s;">
      <div class="form-group mb-4">
        <%= f.label :current_password, "現在のパスワード", class: "small text-secondary mb-1" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control border-0 bg-light rounded-pill px-3", placeholder: (resource.line_profile.present? ? "通知設定のみなら入力不要です" : "変更を保存するには入力が必要です") %>
        
        <% if resource.line_profile.present? %>
          <div class="mt-3 p-3 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-4 animate-pulse">
            <div class="d-flex align-items-center">
              <div class="flex-shrink-0">
                <i class="bi bi-shield-check text-success fs-4 me-2"></i>
              </div>
              <div>
                <p class="extra-small text-dark fw-bold mb-0">LINEログイン済み</p>
                <p class="extra-small text-dark mb-0">通知設定のみの変更ならパスワードは不要です！</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <%= f.submit "設定を保存する", class: "btn btn-vibrant w-100 rounded-pill py-2 shadow-sm fw-bold" %>
    </div>
  <% end %>

  <!-- 外部連携設定 (フォームの外側) -->
  <!-- LINE連携設定 -->
  <div class="glass-card mb-4 animate-entrance" style="animation-delay: 0.25s;">
    <h3 class="h6 font-weight-bold mb-3 d-flex align-items-center">
      <i class="bi bi-line text-success me-2 fs-5"></i>LINE連携設定
    </h3>
    
    <div class="d-flex align-items-center justify-content-between mb-3">
      <div>
        <span class="extra-small text-secondary fw-bold">現在のステータス</span>
      </div>
      <% if resource.line_profile.present? %>
        <span class="badge bg-success rounded-pill px-3 py-1">連携済み</span>
      <% else %>
        <span class="badge bg-light text-secondary rounded-pill px-3 py-1 border border-secondary-subtle">未連携</span>
      <% end %>
    </div>

    <% unless resource.line_profile.present? %>
      <div class="bg-success bg-opacity-10 border border-success border-opacity-25 p-4 mb-3 text-center" style="border-radius: 24px;">
        <p class="extra-small text-dark fw-bold mb-3">通知を有効にするには安全なアカウント連携が必要です</p>
        <%= button_to user_line_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "btn btn-sm btn-success rounded-pill px-4 py-2 fw-bold" do %>
          <i class="bi bi-line me-1"></i>LINEと連携する (ログイン)
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- ブラウザ通知設定 (Web Push) -->
  <div class="glass-card mb-4 animate-entrance" style="animation-delay: 0.28s;" data-controller="web-push" data-web-push-vapid-key-value="<%= ENV['VAPID_PUBLIC_KEY'] %>">
    <h3 class="h6 font-weight-bold mb-3 d-flex align-items-center">
      <i class="bi bi-laptop text-info me-2 fs-5"></i>ブラウザ・端末通知設定
    </h3>
    
    <div class="bg-info bg-opacity-10 border border-info border-opacity-25 p-3 mb-2 text-center" style="border-radius: 20px;">
      <p class="extra-small text-dark fw-bold mb-3">LINEを連携しない場合でも、お使いの端末（スマホ・PC）に直接リマインドを届けることができます。</p>
      <button type="button" data-web-push-target="button" data-action="click->web-push#subscribe" class="btn btn-sm btn-outline-info rounded-pill px-4 py-2 fw-bold w-100">
        <i class="bi bi-bell-fill me-1"></i>このブラウザで通知を受け取る
      </button>
    </div>
    <p class="extra-small text-secondary text-center mb-0 opacity-75">※iOS/Macの場合は Safari でご利用ください</p>
  </div>

  <!-- 注意セクション -->
  <div class="glass-card border-danger-subtle animate-entrance" style="animation-delay: 0.5s; background: rgba(220, 53, 69, 0.02) !important;">
    <h3 class="h6 font-weight-bold mb-3">⚠️ 注意</h3>
    <p class="extra-small mb-3">アカウントを削除すると、これまでの獲得履歴や実績データはすべて失われます。</p>
    <%= button_to "アカウントを削除する", registration_path(resource_name), data: { confirm: "本当に退会しますか？", turbo_confirm: "本当に退会しますか？" }, method: :delete, class: "btn btn-sm text-danger-soft w-100 py-2" %>
  </div>
</div>
