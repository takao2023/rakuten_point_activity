<div class="container d-flex flex-column justify-content-center min-vh-100 py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">
      <div class="text-center mb-5 animate-entrance">
        <h1 class="fw-bold text-white display-6 mb-2">楽天ポイ活マネジメント</h1>
        <p class="text-white opacity-75">あなた専用のポイ活意思決定エンジンを始めましょう。</p>
      </div>

      <div class="glass-card animate-entrance shadow-lg" style="animation-delay: 0.2s;">
        <h2 class="h5 font-weight-bold text-center mb-4">アカウント新規登録</h2>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="mb-3">
            <%= f.label :email, "メールアドレス", class: "small text-secondary mb-1 ms-2" %>
            <div class="input-group rounded-pill overflow-hidden bg-light border-0 shadow-sm px-3">
              <span class="input-group-text bg-transparent border-0 text-secondary pe-0">
                <i class="bi bi-envelope"></i>
              </span>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control bg-transparent border-0 py-3", placeholder: "example@mail.com" %>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :password, "パスワード", class: "small text-secondary mb-1 ms-2" %>
            <div class="input-group rounded-pill overflow-hidden bg-light border-0 shadow-sm px-3">
              <span class="input-group-text bg-transparent border-0 text-secondary pe-0">
                <i class="bi bi-lock"></i>
              </span>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control bg-transparent border-0 py-3", placeholder: "6文字以上で設定してください" %>
            </div>
          </div>

          <div class="mb-4">
            <%= f.label :password_confirmation, "パスワード確認", class: "small text-secondary mb-1 ms-2" %>
            <div class="input-group rounded-pill overflow-hidden bg-light border-0 shadow-sm px-3">
              <span class="input-group-text bg-transparent border-0 text-secondary pe-0">
                <i class="bi bi-shield-check"></i>
              </span>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control bg-transparent border-0 py-3", placeholder: "確認のため、もう一度入力してください" %>
            </div>
          </div>

          <%= f.submit "無料で登録する", class: "btn btn-vibrant w-100 rounded-pill py-3 fw-bold shadow-sm mb-3" %>
        <% end %>

        <div class="position-relative text-center my-3">
          <hr class="text-secondary opacity-25">
          <span class="bg-white px-2 small text-secondary position-absolute top-50 start-50 translate-middle">または</span>
        </div>

        <%= button_to user_line_omniauth_authorize_path, data: { turbo: false }, class: "btn w-100 rounded-pill py-3 fw-bold shadow-sm mb-4 d-flex align-items-center justify-content-center", style: "background-color: #06C755; color: white; border: none;" do %>
          <i class="bi bi-line fs-5 me-2"></i> LINEで登録・ログイン
        <% end %>

        <div class="text-center">
          <p class="small text-secondary mb-0">すでにアカウントをお持ちですか？</p>
          <%= link_to "ログインはこちら", new_session_path(resource_name), class: "fw-bold text-primary text-decoration-none small text-vibrant" %>
        </div>
      </div>

      <div class="text-center mt-4 animate-entrance" style="animation-delay: 0.4s;">
        <%= link_to root_path, class: "text-white opacity-50 text-decoration-none extra-small" do %>
          <i class="bi bi-arrow-left me-1"></i>トップページへ戻る
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
.form-control:focus {
  box-shadow: none;
}
.extra-small {
  font-size: 0.75rem;
}
.input-group:focus-within {
  background: #fff !important;
  box-shadow: 0 0 0 2px rgba(var(--primary-rgb), 0.2) !important;
}
/* テキストにもグラデーションを適用（一部のリンク用） */
.text-vibrant {
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: inline-block;
}
</style>