  <!-- Greeting & Summary Card -->
  <div id="achievement_notifications"></div>
  
  <div class="glass-card mb-4 animate-entrance" style="animation-delay: 0.1s;">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h2 class="h5 mb-2 d-flex align-items-center flex-wrap fw-bold">
          <span class="me-2"><%= @greeting_emoji %> <%= @greeting %></span>
          <span><%= @today_date.strftime("%-m月%-d日") %>のポイ活状況を確認しましょう！！</span>
        </h2>
        <div class="d-flex flex-wrap gap-4 mt-2">
          <p class="text-secondary fw-bold mb-0 fs-5">
            <i class="bi bi-flag-fill me-1 text-primary"></i>今月の目標: <span class="text-primary"><%= number_with_delimiter(@target_points) %></span> <small class="small">pt</small>
          </p>
          <p class="text-secondary fw-bold mb-0 fs-5">
            <i class="bi bi-graph-up-arrow me-1 text-primary"></i>今月の獲得ポイント: <span class="text-primary"><%= number_with_delimiter(@month_points) %></span> <small class="small">pt</small>
          </p>
          <p class="text-secondary fw-bold mb-0 fs-5">
            <i class="bi bi-calendar-event me-1 text-primary"></i>今日の獲得ポイント: <span class="text-primary"><%= number_with_delimiter(@today_points) %></span> <small class="small">pt</small>
          </p>
        </div>
      </div>
      
      <% unless current_user.line_profile.present? %>
        <%= button_to user_line_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "btn btn-sm btn-success rounded-pill px-3 py-1 fw-bold extra-small d-flex align-items-center" do %>
          <i class="bi bi-line me-1 fs-6"></i>LINEと連携
        <% end %>
      <% end %>
    </div>
    
    <div class="mb-3">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="small font-weight-bold text-gradient">今月の達成度</span>
        <span class="small font-weight-bold text-gradient"><%= @month_achievement_percent %>%</span>
      </div>
      <div class="progress rounded-pill bg-light" style="height: 8px;">
        <div class="progress-bar bg-success rounded-pill" role="progressbar" style="width: <%= @month_achievement_percent %>%"></div>
      </div>
    </div>

    <div>
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="small font-weight-bold text-gradient">今日のペース（対目標平均）</span>
        <span class="small font-weight-bold text-gradient"><%= @today_pace_percent %>%</span>
      </div>
      <div class="progress rounded-pill bg-light" style="height: 8px;">
        <div class="progress-bar bg-info rounded-pill" role="progressbar" style="width: <%= [@today_pace_percent, 100].min %>%"></div>
      </div>
    </div>
  </div>

  <!-- 🤖 AIポイ活アドバイザー（執事） -->
  <% if @latest_ai_advice.present? %>
    <div class="glass-card mb-4 animate-entrance border-primary border-opacity-25" style="animation-delay: 0.15s; background: rgba(99, 102, 241, 0.05) !important;">
      <div class="d-flex align-items-start">
        <div class="me-3 mt-1">
          <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm" style="width: 48px; height: 48px; border: 2px solid #6366f1;">
            <i class="bi bi-person-workspace text-primary fs-4"></i>
          </div>
        </div>
        <div class="flex-grow-1">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <h3 class="h6 fw-bold mb-0 text-primary">AIポイ活アドバイザー（執事）</h3>
            <span class="extra-small text-secondary"><%= @latest_ai_advice.generated_at.strftime("%-m/%-d %H:%M") %></span>
          </div>
          <div class="text-dark small leading-relaxed" style="white-space: pre-wrap;"><%= @latest_ai_advice.content %></div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="hero-cta animate-entrance" style="animation-delay: 0.2s;">
    <div class="position-absolute" style="top: 10px; right: 15px; opacity: 0.2; font-size: 4rem;">
      <i class="bi bi-rocket-takeoff text-white"></i>
    </div>
    <div class="position-relative z-1">
      <h3 class="h4 text-white fw-bold mb-3">今日の成果を記録して、データ化しましょう！</h3>
      <p class="text-white-50 small mb-4">継続は力なり。今日の頑張りをしっかりと残しましょう。</p>
      <%= link_to point_activity_targets_path, class: "btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold text-primary shadow-lg border-0" do %>
        <i class="bi bi-pencil-square me-2"></i>成果を登録しにいく
      <% end %>
    </div>
  </div>

  <!-- フローティング登録ボタン -->
  <%= link_to point_activity_targets_path, class: "btn-fab animate-entrance", style: "animation-delay: 1s;", id: "fab-register" do %>
    <i class="bi bi-plus-lg"></i>
  <% end %>


  <!-- Month Progress & Streaks -->
  <div class="row g-3">
    <div class="col-12 col-md-4 animate-entrance" style="animation-delay: 0.5s;">
      <div class="glass-card h-100 d-flex flex-column justify-content-between" id="monthly_achievement_card_top">
        <h3 class="h6 font-weight-bold mb-3"><i class="bi bi-pie-chart-fill text-primary me-2"></i>あなたのポイ活利用率(TOP5)</h3>
        <div style="position: relative;">
          <%= pie_chart @activity_usage_data_top, 
                donut: true, 
                height: "200px",
                colors: @chart_colors, 
                legend: "bottom",
                library: { 
                  responsive: true,
                  maintainAspectRatio: false,
                  cutout: "70%",
                  plugins: {
                    legend: {
                      display: true,
                      position: 'bottom',
                      labels: {
                        usePointStyle: true,
                        padding: 15,
                        font: { size: 10 }
                      }
                    },
                    tooltip: { enabled: true }
                  }
                } %>
          <div style="position: absolute; top: 38%; left: 50%; transform: translate(-50%, -50%); text-align: center; pointer-events: none;">
            <p class="h5 font-weight-bold mb-0 text-gradient"><%= @month_points_top %></p>
            <p class="extra-small text-secondary mb-0">Total pt</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 📉 ポイ活利用率(下位) -->
    <div class="col-12 col-md-4 animate-entrance" style="animation-delay: 0.55s;">
      <div class="glass-card h-100 d-flex flex-column justify-content-between" id="monthly_achievement_card_low">
        <h3 class="h6 font-weight-bold mb-3"><i class="bi bi-pie-chart-fill text-secondary me-2"></i>あなたのポイ活利用率(下位)</h3>
        <div style="position: relative;">
          <% if @activity_usage_data_low.any? %>
            <%= pie_chart @activity_usage_data_low, 
                  donut: true, 
                  height: "200px",
                  colors: ["#94a3b8", "#cbd5e1", "#e2e8f0"], 
                  legend: "bottom",
                  library: { 
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: "70%",
                    plugins: {
                      legend: {
                        display: true,
                        position: 'bottom',
                        labels: {
                          usePointStyle: true,
                          padding: 15,
                          font: { size: 10 }
                        }
                      }
                    }
                  } %>
            <div style="position: absolute; top: 38%; left: 50%; transform: translate(-50%, -50%); text-align: center; pointer-events: none;">
              <p class="h5 font-weight-bold mb-0 text-secondary"><%= @month_points_low %></p>
              <p class="extra-small text-secondary mb-0">Total pt</p>
            </div>
          <% else %>
            <div class="d-flex align-items-center justify-content-center" style="height: 200px;">
              <p class="text-secondary small">下位項目はありません</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    
    <div class="col-12 col-md-4 animate-entrance" style="animation-delay: 0.6s;">
      <div class="glass-card h-100 d-flex flex-column justify-content-center text-center py-4">
        <h3 class="h6 font-weight-bold mb-4">
          <i class="bi bi-fire text-danger me-2"></i>連続達成記録
        </h3>
        
        <div class="position-relative mb-3">
          <div class="streak-circle m-auto d-flex align-items-center justify-content-center">
            <div class="text-center">
              <span class="display-3 font-weight-bold text-gradient d-block" id="streak_count"><%= @user_streak.current_streak %></span>
              <span class="small text-secondary fw-bold">DAYS STREAK</span>
            </div>
          </div>
        </div>

        <div class="mt-2">
          <p class="text-secondary small mb-0 opacity-75">
            <i class="bi bi-trophy-fill text-warning me-1"></i>
            最高記録: <%= @user_streak.longest_streak || 0 %>日
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- 📊 ポイント推移グラフ -->
  <div class="glass-card mt-4 animate-entrance" style="animation-delay: 0.7s;" data-controller="dashboard-chart">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3 class="h6 font-weight-bold mb-0">
        <i class="bi bi-bar-chart-line-fill text-primary me-2"></i>ポイント獲得推移
      </h3>
      <div class="btn-group btn-group-sm" role="group">
        <button type="button" class="btn btn-sm rounded-pill px-3 chart-toggle active" data-action="click->dashboard-chart#toggleDaily" data-dashboard-chart-target="btnDaily">日別</button>
        <button type="button" class="btn btn-sm rounded-pill px-3 ms-1 chart-toggle" data-action="click->dashboard-chart#toggleWeekly" data-dashboard-chart-target="btnWeekly">週別</button>
      </div>
    </div>
    <div id="chart-daily" data-dashboard-chart-target="dailyChart">
      <%= line_chart @daily_chart_data,
            height: "200px",
            colors: ["#6366f1"],
            curve: false,
            points: true,
            library: {
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { ticks: { maxTicksLimit: 7 } }
              },
              plugins: {
                legend: { display: false }
              },
              elements: {
                point: { radius: 5, hoverRadius: 7 },
                line: { tension: 0, borderWidth: 2 }
              }
            } %>
    </div>
    <div id="chart-weekly" style="display: none;" data-dashboard-chart-target="weeklyChart">
      <%= line_chart @weekly_chart_data,
            height: "200px",
            colors: ["#ec4899"],
            curve: false,
            points: true,
            library: {
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } },
                x: { ticks: { maxTicksLimit: 6 } }
              },
              plugins: {
                legend: { display: false }
              },
              elements: {
                point: { radius: 5, hoverRadius: 7 },
                line: { tension: 0, borderWidth: 2 }
              }
            } %>
    </div>
  </div>

  <!-- 🏆 注目のオススメ活動 -->
  <% if @recommended_activities.any? %>
  <div class="glass-card mt-4 animate-entrance mb-4" style="animation-delay: 0.8s;">
    <h3 class="h6 font-weight-bold mb-3">
      <i class="bi bi-star-fill text-warning me-2"></i>注目のオススメ活動
    </h3>
    <div class="row g-3">
      <% @recommended_activities.each_with_index do |activity, index| %>
        <div class="col-12">
          <div class="d-flex align-items-center p-3 rounded-4" style="background: rgba(99, 102, 241, <%= 0.08 - (index * 0.02) %>); border: 1px solid rgba(99, 102, 241, 0.1);">
            <div class="d-flex align-items-center justify-content-center rounded-circle me-3" style="width: 36px; height: 36px; background: var(--accent-gradient); flex-shrink: 0;">
              <span class="text-white fw-bold small"><%= index + 1 %></span>
            </div>
            <div class="flex-grow-1">
              <p class="mb-0 fw-bold small">
                <%= activity.major_item %>
                <% if activity.platform.present? %>
                  <span class="badge bg-light text-secondary border extra-small ms-1"><%= activity.platform %></span>
                <% end %>
              </p>
              <p class="mb-0 text-secondary extra-small">
                <%= activity.service.name %>
              </p>
            </div>
            <div class="text-end">
              <div class="text-warning small">
                <% (activity.recommendation_level || 1).times do %>
                  <i class="bi bi-star-fill"></i>
                <% end %>
                <% (3 - (activity.recommendation_level || 1)).times do %>
                  <i class="bi bi-star text-muted opacity-25"></i>
                <% end %>
              </div>
              <span class="text-secondary extra-small d-block mt-1"><%= activity.frequency %></span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <% end %>

  <!-- 🏆 実績コレクション -->
  <div class="glass-card mt-4 animate-entrance mb-5" style="animation-delay: 0.9s;">
    <h3 class="h6 font-weight-bold mb-3">
      <i class="bi bi-trophy-fill text-warning me-2"></i>実績コレクション
    </h3>
    
    <div class="d-flex flex-wrap gap-3 justify-content-start">
      <% Achievement.all.each do |achievement| %>
        <% earned = current_user.achievements.include?(achievement) %>
        <div class="achievement-badge <%= earned ? 'earned' : 'locked' %>" 
             data-bs-toggle="tooltip" 
             data-bs-placement="top" 
             title="<%= earned ? achievement.description : '未獲得の実績です' %>">
          <div class="badge-icon shadow-sm mb-1"><%= earned ? achievement.icon : '🔒' %></div>
          <p class="extra-small mb-0 text-center fw-bold line-clamp-1" style="width: 70px; font-size: 0.65rem;">
            <%= achievement.name %>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <style>
    .achievement-badge {
      display: flex;
      flex-direction: column;
      align-items: center;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      cursor: pointer;
    }
    .achievement-badge.locked {
      opacity: 0.5;
      filter: grayscale(1);
    }
    .achievement-badge:hover {
      transform: translateY(-8px) scale(1.05);
    }
    .badge-icon {
      width: 60px;
      height: 60px;
      background: var(--glass-bg);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
      border-radius: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      transition: all 0.3s ease;
    }
    .achievement-badge.earned .badge-icon {
      border: 2px solid rgba(99, 102, 241, 0.3);
      background: rgba(255, 255, 255, 0.6);
    }
    .achievement-badge.locked .badge-icon {
      background: rgba(0, 0, 0, 0.05);
      border: 1px dashed rgba(148, 163, 184, 0.5);
    }
    .achievement-badge.earned:hover .badge-icon {
      border-color: var(--accent-primary);
      box-shadow: 0 10px 20px rgba(99, 102, 241, 0.15);
      background: white;
    }
    .achievement-badge p {
      transition: color 0.3s ease;
    }
    .achievement-badge.earned:hover p {
      color: var(--accent-primary) !important;
    }
  </style>

</div>


