<%= form_with(model: point_activity_get, local: true, data: { turbo: false }) do |f| %>
  <% if point_activity_get.errors.any? %>
    <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4 small">
      <ul class="mb-0">
        <% point_activity_get.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%= f.hidden_field :user_id, value: current_user.id %>
  
  <% if point_activity_get.point_activity_id.present? %>
    <% activity = PointActivity.find(point_activity_get.point_activity_id) %>
    <div class="mb-4 d-flex align-items-center">
      <div class="activity-icon me-3">
        <i class="bi bi-coin text-warning fs-4"></i>
      </div>
      <div class="overflow-hidden">
        <h3 class="h6 font-weight-bold mb-0 text-truncate"><%= activity.full_title %></h3>
        <p class="extra-small text-secondary mb-0">この案件の獲得ポイントを入力してください</p>
      </div>
    </div>
    <%= f.hidden_field :point_activity_id %>
  <% else %>
    <div class="mb-4">
      <%= f.label :point_activity_id, "案件を選択", class: "small text-secondary mb-2 d-block" %>
      <%= f.collection_select :point_activity_id, PointActivity.all, :id, :full_title, 
          { prompt: "案件を選択してください" }, 
          { class: "form-select rounded-pill border shadow-sm px-4 py-2 small" } %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :get_point, "獲得ポイント数", class: "small text-secondary mb-2 d-block" %>
    <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden border">
      <%= f.number_field :get_point, class: "form-control border-0 bg-white px-4 fw-bold text-gradient", min: 1, placeholder: "0", autofocus: true %>
      <span class="input-group-text border-0 bg-white text-secondary pe-4">pt</span>
    </div>
  </div>

  <div class="mt-5 pt-3">
    <%= f.submit "実績を登録する", class: "btn btn-vibrant w-100 rounded-pill py-3 fw-bold shadow-sm" %>
    <%= link_to "キャンセル", point_activity_targets_path, class: "btn btn-link text-secondary w-100 mt-2 small text-decoration-none" %>
  </div>
<% end %>