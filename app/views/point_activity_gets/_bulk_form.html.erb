<%= turbo_frame_tag frame_id do %>
  <%= form_with url: bulk_create_point_activity_gets_path, method: :post, class: "d-flex align-items-center gap-1 animate-entrance" do |f| %>
    <%= hidden_field_tag :service_id, service.id %>
    
    <div class="input-group input-group-sm" style="max-width: 100px;">
      <%= number_field_tag :total_point, nil, placeholder: "総額", class: "form-control fw-bold text-center", style: "border-radius: 20px 0 0 20px; border: none; background: rgba(255,255,255,0.9);", autofocus: true %>
      <span class="input-group-text bg-white border-0 small">pt</span>
    </div>
    
    <button type="submit" class="btn btn-vibrant btn-sm fw-bold px-2 shadow-sm" style="border-radius: 0 15px 15px 0;">
      <i class="bi bi-check-lg"></i>
    </button>
    
    <%= link_to bulk_new_point_activity_gets_path(service_id: service.id, cancel: true), class: "btn btn-link text-white-50 p-0 ms-1", data: { turbo_frame: "_self" } do %>
      <i class="bi bi-x-lg" style="font-size: 0.8rem;"></i>
    <% end %>
  <% end %>
<% end %>
