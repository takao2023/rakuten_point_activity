<!DOCTYPE html>
<html>
  <head>
    <title>楽ポイ活マネジメント</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= yield(:meta_description) %>">
    <% else %>
      <meta name="description" content="買い物に頼らない毎日のポイ活を習慣化。習慣化コンサルとして伴走するポイ活マネジメントサービスです。">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <% is_landing_page = controller_name == 'pages' && action_name == 'home' %>

  <body class="top_body d-flex flex-column min-vh-100">
    <% unless is_landing_page %>
      <div class="bg-slideshow"></div>
    <% end %>

    <% unless is_landing_page %>
      <%= render "layouts/header" %>
    <% end %>

    <main class="flex-grow-1 <%= 'mb-5 pb-5 mt-4' unless is_landing_page %>" style="<%= 'padding: 0; margin: 0;' if is_landing_page %>">
      <% unless is_landing_page %>
        <div class="container-fluid">
          <%= render 'layouts/flash-message' %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <% unless is_landing_page %>
      <div class="mt-auto">
        <%= render 'layouts/footer' %>
      </div>
    <% end %>

    <% if current_user && !is_landing_page %>
    <nav class="bottom-nav d-sm-none">
      <a href="<%= dashboards_path %>" class="nav-item-bottom <%= 'active' if current_page?(dashboards_path) %>">
        <i class="bi bi-house-door-fill"></i>
        <span>ホーム</span>
      </a>
      <a href="<%= courses_path %>" class="nav-item-bottom <%= 'active' if current_page?(courses_path) rescue false %>">
        <i class="bi bi-compass"></i>
        <span>コース</span>
      </a>
      <a href="<%= report_point_activity_targets_path %>" class="nav-item-bottom <%= 'active' if current_page?(report_point_activity_targets_path) %>">
        <i class="bi bi-check2-square"></i>
        <span>報告</span>
      </a>
      <a href="<%= point_activity_targets_path %>" class="nav-item-bottom <%= 'active' if current_page?(point_activity_targets_path) %>">
        <i class="bi bi-bar-chart-line"></i>
        <span>進捗</span>
      </a>
      <a href="<%= campaigns_path %>" class="nav-item-bottom <%= 'active' if current_page?(campaigns_path) %>">
        <i class="bi bi-calendar3"></i>
        <span>カレンダー</span>
      </a>
      <a href="<%= achievements_path %>" class="nav-item-bottom <%= 'active' if current_page?(achievements_path) %>">
        <i class="bi bi-award-fill"></i>
        <span>実績</span>
      </a>
      <a href="<%= edit_user_registration_path %>" class="nav-item-bottom <%= 'active' if current_page?(edit_user_registration_path) %>">
        <i class="bi bi-gear-fill"></i>
        <span>設定</span>
      </a>
    </nav>
    
    <!-- 全画面共通フローティングボタン (オススメ攻略記事へ) -->
    <%= link_to dashboards_path(anchor: 'strategy_section'), 
                class: "btn-fab-expandable animate-entrance", 
                style: "animation-delay: 0.5s;", 
                id: "fab-strategy",
                title: "攻略記事を読みに行こう！" do %>
      <i class="bi bi-book-half"></i>
      <span class="fab-text">攻略記事を読みに行こう！</span>
    <% end %>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
    <%= yield :modals %>
  </body>
</html>