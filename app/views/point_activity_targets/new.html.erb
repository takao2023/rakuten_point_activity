<div class="container-fluid py-4 px-md-5">
  <% if @ai_report.present? %>
    <div class="glass-card mb-5 border-0 shadow-sm animate-entrance" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(236, 72, 153, 0.08) 100%); border-radius: 20px;">
      <div class="card-body p-4">
        <div class="d-flex align-items-center mb-3">
          <div class="icon-box bg-white bg-opacity-50 me-3 shadow-sm" style="width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-robot text-primary fs-5"></i>
          </div>
          <div>
            <h4 class="h6 fw-bold mb-1 text-dark">Gemini からの推奨レポート</h4>
            <div class="extra-small text-secondary opacity-75"><%= @ai_report.generated_at.strftime("%Y/%m/%d") %> 更新</div>
          </div>
        </div>
        <p class="small text-secondary mb-0" style="line-height: 1.7; letter-spacing: 0.02em;">
          <%= @ai_report.content %>
        </p>
      </div>
    </div>
  <% end %>

  <div class="row">
    <% 
      icon_map = {
        "広告タップ" => "bi-megaphone",
        "ゲームクリア" => "bi-controller",
        "ミッションクリア" => "bi-check2-circle",
        "ニュース記事閲覧" => "bi-newspaper",
        "ポイント獲得" => "bi-coin",
        "クーポン使用" => "bi-ticket-perforated",
        "ポイント貯金" => "bi-piggy-bank",
        "ながら" => "bi-headphones",
        "毎日くじ" => "bi-stars"
      }
    %>

    <% @point_activities.each do |category, activities| %>
      <div class="col-12 mb-5">
        <h3 class="h5 fw-bold mb-3 d-flex align-items-center opacity-75">
          <i class="bi <%= icon_map[category] || 'bi-bookmark-star' %> me-2 text-primary"></i>
          <%= category %>
        </h3>
        
        <div class="row g-4">
          <% activities.each do |pa| %>
            <div class="col-12 col-md-6 col-xl-4">
              <div class="card glass-card-large h-100 cursor-pointer animate-entrance" 
                   data-bs-toggle="offcanvas" 
                   data-bs-target="#offcanvasActivity<%= pa.id %>">
                <div class="card-body p-4 d-flex flex-column">
                  <div class="mb-auto">
                    <h4 class="fw-bold mb-2 text-dark" style="font-size: 0.9rem; opacity: 0.8;"><%= pa.service.name %></h4>
                    <h5 class="fw-bold text-primary mb-3" style="font-size: 1.25rem;"><%= pa.major_item %><%= pa.small_item.present? ? "（#{pa.small_item}）" : "" %></h5>
                    <p class="small text-secondary line-clamp-2">
                      <%= pa.description.presence || "#{pa.service.name}の#{pa.major_item}です。" %>
                    </p>
                  </div>
                  
                  <div class="mt-4 d-flex align-items-center justify-content-between pt-3 border-top border-dark border-opacity-10">
                    <% if pa.service.official_url.present? %>
                      <%= link_to pa.service.official_url, target: "_blank", rel: "noopener", class: "extra-small fw-bold text-vibrant text-decoration-none d-flex align-items-center" do %>
                        <i class="bi bi-box-arrow-up-right me-1"></i>ポイ活ページで確認
                      <% end %>
                    <% else %>
                      <span class="extra-small fw-bold text-secondary opacity-50">リンクなし</span>
                    <% end %>
                    <div class="text-warning extra-small">
                      <%= pa.recommendation_stars %>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- プレミアム詳細サイドバー (Offcanvas) -->
            <div class="offcanvas offcanvas-end glass-sidebar" tabindex="-1" id="offcanvasActivity<%= pa.id %>">
              <div class="offcanvas-header border-bottom py-4">
                <div class="offcanvas-title h5 fw-bold mb-0">
                  <%= pa.major_item %> 詳細
                </div>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
              </div>
              
              <div class="offcanvas-body p-4 d-flex flex-column">
                  <section class="mb-3">
                    <div class="d-flex align-items-center mb-3">
                      <i class="bi bi-lightbulb text-warning fs-4 me-2"></i>
                      <h6 class="fw-bold mb-0">詳細・攻略のコツ</h6>
                    </div>
                    <div class="p-3 rounded-3 mb-3" style="background-color: var(--bg-primary); border: 1px solid var(--glass-border);">
                      <p class="text-secondary small mb-0 leading-relaxed">
                        <%= pa.description.presence || "現在、詳細な攻略情報は登録されていません。" %>
                      </p>
                    </div>
                  </section>

                <section class="mb-4 text-center">
                  <div class="p-4 rounded-4" style="background: rgba(99, 102, 241, 0.05); border: 1px solid rgba(99, 102, 241, 0.1);">
                    <h5 class="fw-bold text-primary mb-4" style="font-size: 1.1rem;">ご活用ください！</h5>
                    
                    <% if pa.strategy_url.present? %>
                      <%= link_to pa.strategy_url, target: "_blank", class: "btn btn-vibrant w-100 py-3 mb-2 shadow-lg d-flex align-items-center justify-content-center", style: "font-size: 1.05rem;" do %>
                        <i class="bi bi-box-arrow-up-right me-2"></i>攻略サイトへ進む
                      <% end %>
                      <% if pa.service.official_url.present? %>
                        <%= link_to pa.service.official_url, target: "_blank", class: "extra-small text-secondary opacity-75 text-decoration-underline" do %>
                          公式サイトはこちら
                        <% end %>
                      <% end %>
                    <% elsif pa.service.official_url.present? %>
                      <%= link_to pa.service.official_url, target: "_blank", class: "btn btn-vibrant w-100 py-3 shadow-lg d-flex align-items-center justify-content-center", style: "font-size: 1.05rem;" do %>
                        <i class="bi bi-box-arrow-up-right me-2"></i>公式サイトへ進む
                      <% end %>
                    <% else %>
                      <p class="extra-small text-secondary mb-0">リンクは準備中です</p>
                    <% end %>
                  </div>
                </section>

                <section class="mb-5">
                  <h6 class="fw-bold text-primary mb-3">ポイ活概要</h6>
                  <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge border border-primary border-opacity-25 py-2 px-3" style="background-color: rgba(99, 102, 241, 0.1); color: #6366f1;"><%= pa.service.name %></span>
                    <span class="badge border border-success border-opacity-25 py-2 px-3" style="background-color: rgba(16, 185, 129, 0.1); color: #10b981;"><%= pa.category.name %></span>
                    <% if pa.platform.present? %>
                      <span class="badge border border-secondary border-opacity-25 py-2 px-3" style="background-color: rgba(100, 116, 139, 0.1); color: #64748b;"><%= pa.platform %></span>
                    <% end %>
                    <% if pa.frequency.present? %>
                      <span class="badge border border-info border-opacity-25 py-2 px-3" style="background-color: rgba(6, 182, 212, 0.1); color: #0891b2;"><%= pa.frequency %></span>
                    <% end %>
                  </div>
                </section>

                <!-- 過去の獲得実績グラフ -->
                <section class="mb-5">
                  <h6 class="fw-bold d-flex align-items-center mb-3">
                    <i class="bi bi-graph-up-arrow text-success me-2"></i>獲得実績の推移
                  </h6>
                  <div class="glass-card-inner p-3" style="min-height: 180px;">
                    <%
                      # 直近4ヶ月の実績を取得
                      history_data = PointActivityGet.where(point_activity_id: pa.id)
                                                   .where("created_at >= ?", 3.months.ago.beginning_of_month)
                                                   .group_by_month(:created_at, format: "%m月")
                                                   .sum(:get_point)
                    %>
                    <% if history_data.values.any? { |v| v > 0 } %>
                      <%= line_chart history_data, 
                          height: "150px", 
                          colors: ["#6366f1"], 
                          library: { 
                            scales: { 
                              x: { display: true, ticks: { font: { size: 10 } } },
                              y: { display: false } 
                            },
                            plugins: {
                              legend: { display: false },
                              tooltip: {
                                backgroundColor: "rgba(255, 255, 255, 0.9)",
                                titleColor: "#333",
                                bodyColor: "#6366f1",
                                borderColor: "#6366f1",
                                borderWidth: 1,
                                padding: 10,
                                displayColors: false
                              }
                            },
                            elements: {
                              line: { tension: 0.4, borderWidth: 3 },
                              point: { radius: 2, hoverRadius: 5 }
                            }
                          } %>
                    <% else %>
                      <div class="d-flex flex-column align-items-center justify-content-center h-100 py-4 opacity-50">
                        <i class="bi bi-bar-chart-steps fs-3 mb-2"></i>
                        <p class="extra-small mb-0">過去4ヶ月の実績はありません</p>
                      </div>
                    <% end %>
                  </div>
                </section>

                <!-- 公式サイトへのアクション導線 -->
                <div class="mt-auto border-top pt-4">
                  <% if pa.service.official_url.present? %>
                    <div class="glass-card-inner p-4">
                      <h6 class="fw-bold text-primary mb-3 text-center">このポイ活を始める</h6>
                      <div class="d-grid">
                        <%= link_to pa.service.official_url, target: "_blank", rel: "noopener", class: "btn-vibrant-custom text-center py-3" do %>
                          <i class="bi bi-box-arrow-up-right me-2"></i>公式サイトへ進む
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div class="p-4 text-center opacity-50">
                      <i class="bi bi-link-45deg fs-2 mb-2 d-block"></i>
                      <p class="extra-small text-secondary mb-0">このサービスの公式サイトURLは<br>現在登録されていません。</p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .glass-card-large {
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    box-shadow: var(--glass-shadow);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  
  .glass-card-large:hover {
    transform: translateY(-8px);
    background: var(--bg-secondary);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .glass-sidebar {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-left: 1px solid rgba(255, 255, 255, 0.3);
    width: 400px !important;
  }

  .glass-card-inner {
    background: rgba(99, 102, 241, 0.05);
    border-radius: 20px;
    border: 1px solid rgba(99, 102, 241, 0.1);
  }

  .btn-vibrant-custom {
    background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
    color: white !important;
    text-decoration: none;
    border-radius: 99px;
    font-weight: 700;
    font-size: 0.9rem;
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
    transition: all 0.3s ease;
  }

  .btn-vibrant-custom:hover {
    transform: scale(1.02);
    box-shadow: 0 12px 25px rgba(99, 102, 241, 0.4);
    opacity: 0.95;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
