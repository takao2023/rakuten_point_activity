<%= turbo_stream.replace "point-activities-list" do %>
  <div id="point-activities-list" class="row">
    <% @point_activities.each do |pa| %>
      <div class="col-12 col-md-6 mb-3">
        <div class="card glass-card h-100" id="<%= dom_id(pa) %>">
          <div class="card-body">
            <h5 class="card-title fw-bold"><%= pa.point_activity_title %></h5>
            
            <div class="d-flex justify-content-between my-2">
              <span class="text-secondary">当月目標</span>
            <div class="d-flex justify-content-between my-2">
              <span class="text-secondary">当月目標</span>
              <span class="fw-bold"><%= pa.current_month_target %> pt</span>
            </div>

            <div class="d-flex justify-content-between my-2">
              <span class="text-secondary">当月獲得済み</span>
              <span class="fw-bold text-success"><%= pa.current_month_gets %> pt</span>
            </div>

            <% if pa.achievement_rate.present? %>
              <div class="my-2">
                <div class="d-flex justify-content-between">
                  <span class="text-secondary">達成率</span>
                  <span class="fw-bold"><%= pa.achievement_rate %>%</span>
                </div>
                <div class="progress mt-1" style="height: 10px;">
                  <div class="progress-bar bg-success" role="progressbar" style="width: <%= [pa.achievement_rate, 100].min %>%"></div>
                </div>
              </div>
            <% end %>

            <!-- 目標設定画面への遷移ボタン -->
            <div class="mt-3 d-grid">
              <% path = pa.current_target_id.present? ? edit_point_activity_target_path(pa.current_target_id) : ensure_current_month_target_point_activity_targets_path(point_activity_id: pa.id) %>
              <%= link_to path, class: "btn btn-vibrant btn-sm w-100" do %>
                <% if pa.current_month_target > 0 %>
                  目標を変更する
                <% else %>
                  目標を設定する
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- モーダル (これも更新対象に含める) -->
      <div class="modal fade" id="targetModal<%= pa.id %>" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title"><%= pa.point_activity_title %> の目標設定</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <%= form_with url: upsert_point_activity_targets_path, method: :post, local: false, data: { turbo: true } do |f| %>
              <div class="modal-body">
                <%= f.hidden_field :point_activity_id, value: pa.id %>
                <div class="mb-3">
                  <%= f.label :target_point, "今月の目標ポイント数", class: "form-label" %>
                  <%= f.number_field :target_point, value: pa.current_month_target, class: "form-control", required: true, min: 1 %>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">キャンセル</button>
                <%= f.submit "保存する", class: "btn btn-primary", data: { bs_dismiss: "modal" } %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%= turbo_stream.replace "flash-messages" do %>
  <%= render "layouts/flash-message" %>
<% end %>
