<div class="card glass-card h-100" id="<%= dom_id(pa) %>">
  <div class="card-body">
    <%# サービス名と詳細開閉アイコン %>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="card-title fw-bold mb-0 text-primary fs-5"><%= pa.name %></h5>
      <div class="d-flex align-items-center gap-2">
        <%# 一括獲得ボタン %>
        <%= render "point_activity_gets/bulk_button", service: pa %>
        
        <button class="btn btn-link text-primary p-0 shadow-none d-flex align-items-center" 
                type="button" 
                data-bs-toggle="collapse" 
                data-bs-target="#detailsCollapse<%= pa.id %>" 
                aria-expanded="false" 
                aria-controls="detailsCollapse<%= pa.id %>">
          <span class="extra-small fw-bold me-1 text-secondary opacity-75">詳細</span>
          <i class="bi bi-chevron-down fs-5"></i>
        </button>
      </div>
    </div>
    
    <%# サービス全体の実績数値 %>
    <div class="mb-2">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="text-secondary small">当月目標</span>
        <span class="fw-bold text-success"><%= pa.current_month_target(current_user) %> pt</span>
      </div>
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="text-secondary small">当月獲得済み</span>
        <span class="fw-bold text-success"><%= pa.current_month_gets(current_user) %> pt</span>
      </div>
    </div>

    <%# サービス全体の進捗バー %>
    <% rate = pa.achievement_rate(current_user) %>
    <div class="my-3">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="text-secondary extra-small">進捗率</span>
        <span class="fw-bold text-dark" style="font-size: 0.9rem;"><%= rate %>%</span>
      </div>
      <div class="progress shadow-sm" style="height: 10px; border-radius: 5px; background-color: rgba(0,0,0,0.05); border: 1px solid rgba(255,255,255,0.3);">
        <div class="progress-bar bg-vibrant progress-bar-striped progress-bar-animated" 
             role="progressbar" 
             style="width: <%= [rate, 100].min %>%"></div>
      </div>
    </div>

    <%# 詳細項目（大項目・小項目）のリスト %>
    <div class="collapse" id="detailsCollapse<%= pa.id %>">
      <hr class="my-3 opacity-25">
      <div class="list-group list-group-flush bg-transparent">
        <% pa.point_activities.group_by(&:major_item).each do |major_item_name, activities| %>
          <div class="list-group-item bg-transparent border-0 px-0 py-2">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <div class="small fw-bold text-dark opacity-75"><%= major_item_name %></div>
              <%# 最初の項目のオススメ度を代表で表示 %>
              <div class="text-warning extra-small">
                <% (activities.first.recommendation_level || 1).times do %><i class="bi bi-star-fill"></i><% end %>
              </div>
            </div>
            
            <% if activities.size > 1 || activities.first.small_item.present? %>
              <%# 小項目がある場合、または同じ大項目に複数ある場合 %>
              <div class="ps-2 border-start border-primary border-opacity-10 ms-1 mt-1">
                <% activities.each do |activity| %>
                  <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10">
                    <div class="extra-small text-secondary">
                      <%= activity.small_item.present? ? activity.small_item : activity.frequency %>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                      <span class="badge rounded-pill bg-white bg-opacity-25 text-primary extra-small border border-white border-opacity-50 shadow-sm"><%= activity.current_month_gets(current_user) %> pt</span>
                      <%= turbo_frame_tag "get_form_#{activity.id}" do %>
                        <%= link_to new_point_activity_get_path(point_activity_id: activity.id, frame_id: "get_form_#{activity.id}"), 
                                    class: "text-vibrant d-flex align-items-center justify-content-center", 
                                    style: "font-size: 1.2rem;" do %>
                          <i class="bi bi-plus-circle-fill"></i>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <%# 小項目がない単一項目の場合 %>
              <% activity = activities.first %>
              <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-25">
                <div class="extra-small text-secondary"><%= activity.frequency %></div>
                <div class="d-flex align-items-center gap-2">
                  <span class="badge rounded-pill bg-white bg-opacity-25 text-primary extra-small border border-white border-opacity-50 shadow-sm"><%= activity.current_month_gets(current_user) %> pt</span>
                  <%= turbo_frame_tag "get_form_#{activity.id}" do %>
                    <%= link_to new_point_activity_get_path(point_activity_id: activity.id, frame_id: "get_form_#{activity.id}"), 
                                class: "text-vibrant d-flex align-items-center justify-content-center", 
                                style: "font-size: 1.2rem;" do %>
                      <i class="bi bi-plus-circle-fill"></i>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# 掲載先・URLのバッジ %>
      <div class="mt-2 text-end d-flex justify-content-end gap-2 align-items-center">
        <% if pa.platform.present? %>
          <span class="badge bg-light text-secondary border extra-small opacity-50"><%= pa.platform %></span>
        <% end %>
        <% if pa.official_url.present? %>
          <%= link_to pa.official_url, target: "_blank", class: "text-secondary opacity-50 extra-small" do %>
            <i class="bi bi-box-arrow-up-right me-1"></i>URL
          <% end %>
        <% end %>
      </div>
    </div>

    <%# 目標設定への遷移（最初の項目を代表とするか、あるいは一覧へ） %>
    <div class="mt-4 d-grid">
      <% first_activity = pa.point_activities.first %>
      <% target_id = first_activity&.current_target_id(current_user) %>
      <% path = target_id.present? ? edit_point_activity_target_path(target_id) : ensure_current_month_target_point_activity_targets_path(point_activity_id: first_activity&.id) %>
      <%= link_to path, class: "btn btn-vibrant btn-sm w-100 py-2 shadow" do %>
        <% if pa.current_month_target(current_user) > 0 %>
          目標を変更する
        <% else %>
          目標を設定する
        <% end %>
      <% end %>
    </div>
  </div>
</div>
