<div class="card glass-card h-100" id="<%= dom_id(pa) %>">
  <div class="card-body">
    <%# サービス名と詳細開閉アイコン %>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="card-title fw-bold mb-0 text-primary fs-5"><%= pa.name %></h5>
      <div class="d-flex align-items-center gap-2">
        <%# 一括獲得ボタン %>
        <%= render "point_activity_gets/bulk_button", service: pa %>
        
        <button class="btn btn-link text-primary p-0 shadow-none d-flex align-items-center" 
                type="button" 
                data-bs-toggle="collapse" 
                data-bs-target="#detailsCollapse<%= pa.id %>" 
                aria-expanded="false" 
                aria-controls="detailsCollapse<%= pa.id %>">
          <span class="extra-small fw-bold me-1 text-secondary opacity-75">詳細</span>
          <i class="bi bi-chevron-down fs-5"></i>
        </button>
      </div>
    </div>
    
    <%# サービス全体の実績数値 %>
    <div class="mb-2">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="text-secondary small">当月獲得累計</span>
        <span class="fw-bold text-success"><%= pa.current_month_gets(current_user) %> pt</span>
      </div>
      <% 
        today_execs = pa.point_activities.sum { |act| act.today_execution_count(current_user) }
        total_daily_max = pa.point_activities.sum { |act| act.daily_max_executions || 0 }
      %>
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="text-secondary small">今日の完了報告</span>
        <span class="fw-bold text-primary"><%= today_execs %><%= total_daily_max > 0 ? " / #{total_daily_max}" : "" %> 回</span>
      </div>
    </div>

    <%# 詳細項目（大項目・小項目）のリスト %>
    <div class="collapse" id="detailsCollapse<%= pa.id %>">
      <hr class="my-3 opacity-25">
      <div class="list-group list-group-flush bg-transparent">
        <% pa.point_activities.group_by(&:major_item).each do |major_item_name, activities| %>
          <div class="list-group-item bg-transparent border-0 px-0 py-2">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <div class="small fw-bold text-dark opacity-75"><%= major_item_name %></div>
              <%# 最初の項目のオススメ度を代表で表示 %>
              <div class="text-warning extra-small">
                <% (activities.first.recommendation_level || 1).times do %><i class="bi bi-star-fill"></i><% end %>
              </div>
            </div>
            
            <div class="ps-2 border-start border-primary border-opacity-10 ms-1 mt-1">
              <% activities.each do |activity| %>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10">
                  <div class="extra-small text-secondary flex-grow-1">
                    <%= activity.small_item.present? ? activity.small_item : activity.frequency %>
                    <% if activity.time_managed? %>
                      <div class="opacity-75" style="font-size: 0.7rem;">
                        今日: <%= activity.today_execution_count(current_user) %><%= activity.daily_max_executions ? " / #{activity.daily_max_executions}" : "" %>
                      </div>
                    <% end %>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill bg-white bg-opacity-25 text-primary extra-small border border-white border-opacity-50 shadow-sm"><%= activity.current_month_gets(current_user) %> pt</span>
                    <%= render partial: "point_activity_targets/activity_execution_button", locals: { activity: activity } %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# 掲載先・URLのバッジ %>
      <div class="mt-2 text-end d-flex justify-content-end gap-2 align-items-center">
        <% if pa.platform.present? %>
          <span class="badge bg-light text-secondary border extra-small opacity-50"><%= pa.platform %></span>
        <% end %>
        <% if pa.official_url.present? %>
          <%= link_to pa.official_url, target: "_blank", class: "text-secondary opacity-50 extra-small" do %>
            <i class="bi bi-box-arrow-up-right me-1"></i>URL
          <% end %>
        <% end %>
      </div>
    </div>

    <%# 目標設定への遷移を詳細開閉に変更、または一覧へ誘導 %>
    <div class="mt-4 d-grid">
      <button class="btn btn-vibrant btn-sm w-100 py-2 shadow" 
              type="button" 
              data-bs-toggle="collapse" 
              data-bs-target="#detailsCollapse<%= pa.id %>">
        詳細・攻略を見る
      </button>
    </div>
  </div>
</div>
